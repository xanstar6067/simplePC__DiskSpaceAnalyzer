<Window x:Class="DiskSpaceAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:DiskSpaceAnalyzer.Controls"
        xmlns:converters="clr-namespace:DiskSpaceAnalyzer.Converters"
        xmlns:models="clr-namespace:DiskSpaceAnalyzer.Models"
        mc:Ignorable="d"
        Title="Анализатор дискового пространства simplePC"
        Icon="/App.ico"
        MinHeight="720"
        MinWidth="1120"
        Height="800"
        Width="1260"
        Background="#F4F6F8"
        FontFamily="Segoe UI">
    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibility" />
        <converters:RiskWarningVisibilityConverter x:Key="RiskWarningVisibility" />
        <converters:ScanNodeSizeConverter x:Key="ScanNodeSize" />
        <converters:ScanNodePercentConverter x:Key="ScanNodePercent" />

        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D7DDE5" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#5B6470" />
        <SolidColorBrush x:Key="AccentBrush" Color="#2D8074" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#256B62" />

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="BorderBrush" Value="#C8D0DA" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#17202A" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F3F6" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="BorderBrush" Value="#C8D0DA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>

        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#17202A" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="18" />
        </Style>

        <Style x:Key="RightAlignCell" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="RiskCell" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{Binding RiskBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="MutedCell" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ExpanderToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="10"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Text="▶">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                                                         Value="True">
                                                <Setter Property="Text" Value="▼" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Panel}" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
                          MinWidth="320"
                          ItemsSource="{Binding AvailableDrives}"
                          SelectedItem="{Binding SelectedDrive}"
                          DisplayMemberPath="DisplayName" />

                <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Right" Margin="18,0,0,0">
                    <CheckBox Content="Сканировать системные каталоги полностью"
                              VerticalAlignment="Center"
                              IsChecked="{Binding IncludeSystemDirectories}" />
                    <CheckBox Content="Анализировать реальный размер на диске"
                              Margin="0,6,0,0"
                              IsChecked="{Binding AnalyzeSizeOnDisk}" />
                    <CheckBox Content="Примерный размер быстро"
                              Margin="0,6,0,0"
                              IsChecked="{Binding ApproximateSizeOnDisk}" />
                    <CheckBox Content="Игнорировать кэш при сканировании"
                              Margin="0,6,0,0"
                              IsChecked="{Binding IgnoreCache}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Старт"
                                Style="{StaticResource PrimaryButton}"
                                MinWidth="92"
                                Height="44"
                                Command="{Binding StartScanCommand}" />
                        <Button Content="Отмена"
                                MinWidth="92"
                                Margin="8,0,0,0"
                                Height="44"
                                Command="{Binding CancelScanCommand}" />
                    </StackPanel>
                    <Button Content="Очистить кэш"
                            Margin="0,6,0,0"
                            HorizontalAlignment="Stretch"
                            Command="{Binding ClearCacheCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Panel}" Padding="14" Margin="0,12,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Файлы" Style="{StaticResource MetricLabel}" />
                    <TextBlock Text="{Binding ProcessedFilesText}" Style="{StaticResource MetricValue}" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="Папки" Style="{StaticResource MetricLabel}" />
                    <TextBlock Text="{Binding ProcessedDirectoriesText}" Style="{StaticResource MetricValue}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Размер" Style="{StaticResource MetricLabel}" />
                    <TextBlock Text="{Binding LogicalBytesText}" Style="{StaticResource MetricValue}" />
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <TextBlock Text="На диске" Style="{StaticResource MetricLabel}" />
                    <TextBlock Text="{Binding SizeOnDiskBytesText}" Style="{StaticResource MetricValue}" />
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="{Binding StatusSummary}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding CurrentPath}" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
                </StackPanel>

                <Border Grid.Row="1"
                        Grid.ColumnSpan="5"
                        Visibility="{Binding HasCacheWarning, Converter={StaticResource BoolToVisibility}}"
                        Background="#FFF7E6"
                        BorderBrush="#E1B773"
                        BorderThickness="1"
                        CornerRadius="6"
                        Padding="10"
                        Margin="0,12,0,0">
                    <TextBlock Text="{Binding CacheWarningText}" TextWrapping="Wrap" Foreground="#7B4B00" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1.1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Panel}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="ResultsTree"
                              Grid.Row="1"
                              ItemsSource="{Binding FlatNodes}"
                              SelectedItem="{Binding SelectedFlatNode, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#E7EBF0"
                              BorderThickness="0"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#FAFBFC"
                              AlternationCount="2"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              RowHeaderWidth="0"
                              MouseDoubleClick="ResultsTree_MouseDoubleClick"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              EnableRowVirtualization="True"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}" />
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <MenuItem Header="Показать в Проводнике"
                                                      Command="{Binding PlacementTarget.Tag.OpenInExplorerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Копировать путь"
                                                      Command="{Binding PlacementTarget.Tag.CopyPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <Separator />
                                            <MenuItem Header="Обновить эту папку"
                                                      Command="{Binding PlacementTarget.Tag.RefreshNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Исключить из анализа"
                                                      Command="{Binding PlacementTarget.Tag.ExcludeNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <Separator />
                                            <MenuItem Header="Сведения"
                                                      Command="{Binding PlacementTarget.Tag.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#EEF3F8" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#D6E9FF" />
                                        <Setter Property="BorderBrush" Value="#6AA9E9" />
                                    </Trigger>
                                    <DataTrigger Binding="{Binding IsRefreshing}" Value="True">
                                        <Setter Property="Background" Value="#FFF0C7" />
                                        <Setter Property="BorderBrush" Value="#D99A24" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Имя" Width="SizeToCells" MinWidth="160">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="{Binding IndentMargin}">
                                            <ToggleButton Width="16"
                                                          Height="16"
                                                          Margin="0,0,4,0"
                                                          Focusable="False"
                                                          IsChecked="{Binding IsExpanded, Mode=OneWay}"
                                                          PreviewMouseLeftButtonDown="ExpanderToggle_PreviewMouseLeftButtonDown">
                                                <ToggleButton.Style>
                                                    <Style TargetType="ToggleButton" BasedOn="{StaticResource ExpanderToggle}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ChildCount}" Value="0">
                                                                <Setter Property="Visibility" Value="Hidden" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ToggleButton.Style>
                                            </ToggleButton>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       VerticalAlignment="Center"
                                                       Foreground="#17202A" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Размер"
                                                Width="100"
                                                Binding="{Binding LogicalSizeText}"
                                                ElementStyle="{StaticResource RightAlignCell}" />
                            <DataGridTemplateColumn Header="На диске" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Right">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding SizeOnDiskText}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding DataContext.DisplayUsesSizeOnDisk, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                     Value="False">
                                                            <Setter Property="Text" Value="Н/Д" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Доля" Width="72">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock HorizontalAlignment="Right">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource ScanNodePercent}">
                                                    <Binding />
                                                    <Binding Path="DataContext.DisplayUsesSizeOnDisk"
                                                             RelativeSource="{RelativeSource AncestorType=Window}" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Статус"
                                                Width="108"
                                                Binding="{Binding RiskText}"
                                                ElementStyle="{StaticResource RiskCell}" />
                            <DataGridTextColumn Header="Обработка"
                                                Width="118"
                                                Binding="{Binding StatusText}"
                                                ElementStyle="{StaticResource MutedCell}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Panel}" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="260" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="1.2*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="0.8*" />
                    </Grid.RowDefinitions>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="10,0,0,0">
                            <Button Content="Назад"
                                    MinWidth="76"
                                    Command="{Binding NavigateBackCommand}" />
                            <Button Content="Перейти"
                                    MinWidth="76"
                                    Margin="8,0,0,0"
                                    Command="{Binding NavigateToChartNodeCommand}" />
                        </StackPanel>
                        <TextBlock Text="{Binding SelectedNode.DisplayName}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </DockPanel>

                    <controls:DonutChart Grid.Row="1"
                                         ItemsSource="{Binding ChartChildren}"
                                         UseSizeOnDisk="{Binding DisplayUsesSizeOnDisk}"
                                         SliceCommand="{Binding SelectNodeCommand}"
                                         Margin="0,8" />

                    <Border Grid.Row="2"
                            Visibility="{Binding SelectedNode, Converter={StaticResource RiskWarningVisibility}}"
                            Background="#FFF5E9"
                            BorderBrush="#E1B773"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,0,0,10">
                        <TextBlock Text="{Binding SelectedNodeSafetyText}" TextWrapping="Wrap" Foreground="#7B4B00" />
                    </Border>

                    <ListView Grid.Row="3"
                              ItemsSource="{Binding ChartChildren}"
                              SelectedItem="{Binding SelectedChartNode}"
                              MouseDoubleClick="ChartItems_MouseDoubleClick"
                              BorderBrush="#D7DDE5">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}" />
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <MenuItem Header="Показать в Проводнике"
                                                      Command="{Binding PlacementTarget.Tag.OpenInExplorerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Копировать путь"
                                                      Command="{Binding PlacementTarget.Tag.CopyPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <Separator />
                                            <MenuItem Header="Обновить эту папку"
                                                      Command="{Binding PlacementTarget.Tag.RefreshNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <MenuItem Header="Исключить из анализа"
                                                      Command="{Binding PlacementTarget.Tag.ExcludeNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                            <Separator />
                                            <MenuItem Header="Сведения"
                                                      Command="{Binding PlacementTarget.Tag.ShowDetailsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                      CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Крупные элементы" Width="190" DisplayMemberBinding="{Binding DisplayName}" />
                                <GridViewColumn Header="Тип" Width="82" DisplayMemberBinding="{Binding KindText}" />
                                <GridViewColumn Header="Размер" Width="94">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock HorizontalAlignment="Right">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource ScanNodeSize}">
                                                        <Binding />
                                                        <Binding Path="DataContext.DisplayUsesSizeOnDisk"
                                                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Доля" Width="68">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock HorizontalAlignment="Right">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource ScanNodePercent}">
                                                        <Binding />
                                                        <Binding Path="DataContext.DisplayUsesSizeOnDisk"
                                                                 RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <DockPanel Grid.Row="4" Margin="0,12,0,8">
                        <TextBlock Text="Поиск" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBox DockPanel.Dock="Right"
                                 Width="260"
                                 Margin="12,0,0,0"
                                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>

                    <ListBox Grid.Row="5"
                             ItemsSource="{Binding SearchResults}"
                             SelectedItem="{Binding SelectedNode}"
                             BorderBrush="#D7DDE5">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:ScanNode}">
                                <StackPanel Margin="0,4">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding FullPath}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

